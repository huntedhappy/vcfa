# vcfa Tenant 모드 환경값 템플릿.
# 1) cp .env.tenant.example .env.tenant
# 2) VCFA_USER / VCFA_PASS 를 자기 tenant 계정으로 수정 (나머지는 그대로 두면 tenant 모드)
# 3) source scripts/session.sh .env.tenant
#
# ※ 이 파일은 "복사만 하면 tenant 모드" 가 되도록 VCFA_TENANT_ORG 가 이미 설정돼 있음.
#   provider(System) 작업이 필요하면 .env (= cp .env.example .env) 를 쓸 것.

# VCFA FQDN (호스트만, https:// 빼고)
export VCFA_FQDN="vcfa.dtvcf.lab"

# ── Tenant 자격증명 ─────────────────────────────────────────
#  - VCFA_USER     : tenant org 의 user 이름 (예: configadmin, jdoe)
#  - VCFA_TENANT_ORG : 이 값이 설정돼 있으면 tenant 모드. 로그인 시 "<USER>@<ORG>" Basic Auth.
#  - ★ 이 user 는 대상 project 의 멤버여야 blueprint / form / project-service / catalog API 가 200.
#    (멤버가 아니거나 VCFA_TENANT_ORG 가 비면 project-service 가 403)
export VCFA_USER="configadmin"
export VCFA_TENANT_ORG="ProviderConsumptionOrg"

# 비밀번호 — ★ 평문 보관 비권장. 가능하면 read -s 로 받기:
#   read -s -p "VCFA pass: " VCFA_PASS && export VCFA_PASS && echo
export VCFA_PASS="CHANGE-ME"

# VCFA API 버전 (Accept/Content-Type 헤더에 들어감)
export VCFA_API_VERSION="9.1.0"

# VCFA 9.1 Embedded Orchestrator API Base URL
export VCO_API_BASE="https://${VCFA_FQDN}/vco/api"

# VCFA Action Category (com.vmk.dk 등)
export ACTION_CATEGORY="com.vmk.dk"
export ACTION_DIR="/var/tmp/vcfa/actions/${ACTION_CATEGORY}"

# 패키지 이름 (com.dk 등)
export PACKAGE_NAME="com.dk"
# Export 패키지 파일 경로
export EXPORT_FILE="packages/${PACKAGE_NAME}.package"
# Import 패키지 파일 경로
export PACKAGE_FILE="packages/${PACKAGE_NAME}.package"

# 업로드 대상 project (블루프린트/폼이 들어갈 곳)
#   tenant 모드에서는 vcfa_select_project 로 선택하면 VCFA_PROJECT_ID 가 자동 저장됨.
export PROJECT_NAME="ProviderConsumptionOrg"

# 대상 org 식별자 (tenant 모드는 vcfa_select_org 가 자동 채움 — 보통 수정 불필요)
#   - VCFA_ORG_NAME: org 표시 이름
#   - VCFA_ORG_ID  : org URN (Provider UI > Tenants > <org> > More > Copy URN)
#   - ORG_UUID     : VCFA_ORG_ID 의 마지막 UUID 부분만 자동 추출 (수정 금지)
export VCFA_ORG_NAME="ProviderConsumptionOrg"
export VCFA_ORG_ID="urn:vcloud:org:CHANGE-ME-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX"
export ORG_UUID="${VCFA_ORG_ID##*:}"
