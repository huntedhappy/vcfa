# vcfa 업로드용 환경값 템플릿.
# 1) cp .env.example .env
# 2) .env 안의 값을 자기 환경에 맞춰 수정
# 3) source .env 로 현재 셸에 로드 (.env 는 git에 커밋되지 않음)

# VCFA FQDN (호스트만, https:// 빼고)
export VCFA_FQDN="vcfa.dtvcf.lab"

# VCFA 사용자 — 둘 중 한 모드 선택:
#
# [A] Tenant 모드 (Blueprint / Form / CCI namespace / catalog 자동화 필요한 경우, 권장)
#     - VCFA_USER 에는 tenant org 의 user 이름 (예: configadmin, jdoe)
#     - VCFA_TENANT_ORG 를 함께 설정. 로그인 시 자동으로 "<USER>@<ORG>" Basic Auth.
#     - target project 의 멤버여야 blueprint / form / project-service API 가 200.
#
# [B] Provider 모드 (System Admin, 기본)
#     - VCFA_USER 에 System admin (예: admin@system)
#     - VCFA_TENANT_ORG 는 주석 처리 / 비워두기.
#     - Provider 전용 작업만 가능. blueprint/form/CCI namespace 자동화는 RBAC 으로 차단됨.
#
export VCFA_USER="admin@system"
# export VCFA_TENANT_ORG="ProviderConsumptionOrg"   # 주석 해제 = tenant 모드

# 비밀번호 — ★ 평문 보관 비권장. 가능하면 read -s 로 받기:
#   read -s -p "VCFA pass: " VCFA_PASS && export VCFA_PASS && echo
export VCFA_PASS="VMware1!VMware1!"

# VCFA API 버전 (Accept/Content-Type 헤더에 들어감)
export VCFA_API_VERSION="9.1.0"

# VCFA 9.1 Embedded Orchestrator API Base URL
export VCO_API_BASE="https://${VCFA_FQDN}/vco/api"

# VCFA Action Category (com.vmk.dk 등)
export ACTION_CATEGORY="com.vmk.dk"
export ACTION_DIR="/var/tmp/vcfa/actions/${ACTION_CATEGORY}"

# 패키지 이름 (com.dk 등)
export PACKAGE_NAME="com.dk"
# Export 패키지 파일 경로
export EXPORT_FILE="packages/${PACKAGE_NAME}.package"
# Import 패키지 파일 경로
export PACKAGE_FILE="packages/${PACKAGE_NAME}.package"

# 업로드 대상 project (블루프린트/폼이 들어갈 곳, 필요 시)
export PROJECT_NAME="ProviderConsumptionOrg"

# 대상 tenant org 식별자
#   - VCFA_ORG_NAME: org 표시 이름 (예: Org1)
#   - VCFA_ORG_ID  : org URN (Provider UI > Tenants > <org> > More > Copy URN)
#   - ORG_UUID     : VCFA_ORG_ID 의 마지막 UUID 부분만 자동 추출 (수정 금지)
export VCFA_ORG_NAME="Org1"
export VCFA_ORG_ID="urn:vcloud:org:CHANGE-ME-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX"
export ORG_UUID="${VCFA_ORG_ID##*:}"

# ── vCenter (vSphere) — getStorageClass(스토리지 정책) / getVMImage(Content Library) 드롭다운용 ──
#   VCFA 가 아니라 *밑단 vCenter* 자격증명. 채운 뒤 vRO 에 호스트 등록:
#     vcfa_register_vcenter   # getStorageClass 의 스토리지 정책 소스
#     vcfa_register_vapi      # getVMImage 의 Content Library / VM image 소스
export VC_HOST="vcenter.dtvcf.lab"             # 밑단 vCenter FQDN (https:// 빼고) — 본인 환경값
export VC_USER="administrator@vsphere.local"   # vCenter SSO 계정
export VC_PASS="CHANGE-ME"                     # vCenter 비밀번호
# 선택 (기본값 있음)
export VC_PORT="443"                           # vCenter SDK 포트 (기본 443)
export VC_IGNORE_CERT="true"                   # self-signed 인증서 무시 (기본 true)
export VAPI_ENDPOINT_URL="https://${VC_HOST}/api"  # vAPI endpoint (다르면 명시)